{
  "name": "@seanoseanohay/seatbelt",
  "version": "0.3.6",
  "description": "Seatbelt — constitutional governance harness for agentic coding. The harness owns review timing and correction.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "seatbelt": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE*"
  ],
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "seatbelt": "tsx src/cli.ts",
    "test": "node --test test/**/*.test.js",
    "test:unit": "npx tsx --test test/unit/**/*.test.ts",
    "test:integration": "npx tsx --test test/integration/**/*.test.ts",
    "prepare": "node -e \"const fs=require('fs'); if (fs.existsSync('node_modules/.bin/tsc') || fs.existsSync('node_modules/typescript')) { require('child_process').execSync('npm run build', {stdio:'inherit'}); } else { console.log('Skipping build (published package context or no dev deps)'); }\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "seatbelt",
    "governance",
    "constitutional",
    "ai",
    "coding-agent",
    "codex"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seanoseanohay/seatbelt.git"
  },
  "bugs": {
    "url": "https://github.com/seanoseanohay/seatbelt/issues"
  },
  "homepage": "https://seanoseanohay.github.io/seatbelt",
  "license": "MIT",
  "dependencies": {
    "@earendil-works/pi-ai": "latest"
  },
  "overrides": {
    "node-domexception": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
